#!/usr/bin/env bash
set -euo pipefail
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"
PYTHON_BIN="${PYTHON_BIN:-python3}"
if ! command -v "$PYTHON_BIN" >/dev/null 2>&1; then
  if command -v python >/dev/null 2>&1; then
    PYTHON_BIN=python
  else
    echo "ERROR: Python not found."
    exit 1
  fi
fi
"$PYTHON_BIN" tools/coding-standard/scripts/clang_format_staged.py
"$PYTHON_BIN" tools/coding-standard/scripts/clang_tidy_changed.py
